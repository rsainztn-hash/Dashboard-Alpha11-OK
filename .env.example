# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The ID of the Google Sheet to sync with
GOOGLE_SHEET_ID=
# Example: https://your-vercel-project.vercel.app/auth/callback
GOOGLE_REDIRECT_URI=

# Optional, recommended for a public dashboard where viewers should not log in.
# Share the Google Sheet with this service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Optional fallback when Google Cloud blocks service account keys.
# Requires the Google Sheet to be shared/published as view-only for anyone with the link.
GOOGLE_SHEETS_PUBLIC_EXPORT=false
